{
  "npmScope": "workshop",
  "affected": {
    "defaultBase": "main"
  },
  "workspaceLayout": {
    "appsDir": "apps",
    "libsDir": "libs"
  },
  "analytics": false,
  "plugins": ["@nx/vite"],
  "targetDefaults": {
    "build": {
      "cacheable": true,
      "outputs": ["{projectRoot}/dist", "{projectRoot}/build"],
      "dependsOn": ["^build"]
    },
    "test": {
      "cacheable": true,
      "outputs": ["{projectRoot}/coverage"]
    },
    "lint": { "cacheable": true },
    "dev": { "cacheable": false },
    "preview": { "cacheable": false }
  },
  "generators": {}
}