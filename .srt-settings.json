{
	"filesystem": {
		"denyRead": ["~", "/etc", "/var", "/root", "/home"],
		"allowRead": [
			".",
			"~/.local/share/mise/**",
			"~/.nix-profile/bin/**",
			"/tmp/**",
			"/etc/resolv.conf",
			"/etc/hosts",
			"/etc/ssl/certs/**",
			"/etc/ca-certificates/**"
		],
		"allowWrite": [".", "/tmp"],
		"denyWrite": [".env", ".opencode/commands", ".opencode/agents", ".opencode/skills"]
	},
	"network": {
		"allowedDomains": [
			"github.com",
			"*.github.com",
			"raw.githubusercontent.com",
			"registry.npmjs.org",
			"registry.bun.sh",
			"opencode.ai",
			"api.opencode.ai",
			"localhost",
			"127.0.0.1"
		],
		"deniedDomains": []
	}
}
