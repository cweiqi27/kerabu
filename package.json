{
	"name": "workshop",
	"version": "0.0.0",
	"license": "MIT",
	"scripts": {
		"build": "nx run-many --target=build",
		"dev": "nx run-many --target=dev --parallel=3",
		"test": "nx run-many --target=test",
		"lint": "nx run-many --target=lint",
		"preview": "nx run portfolio:preview",
		"build:portfolio": "nx run portfolio:build",
		"dev:portfolio": "nx run portfolio:dev",
		"build:grosshery-web": "nx run grosshery-web:build",
		"dev:grosshery-web": "nx run grosshery-web:dev",
		"test:grosshery-web": "nx run grosshery-web:test",
		"test:unit:grosshery-web": "nx run grosshery-web:test:unit",
		"test:e2e:grosshery-web": "nx run grosshery-web:test:e2e",
		"lint:grosshery-web": "nx run grosshery-web:lint",
		"format:grosshery-web": "nx run grosshery-web:format",
		"check:grosshery-web": "nx run grosshery-web:check",
		"build:grosshery-mobile": "nx run grosshery-mobile:build",
		"dev:grosshery-mobile": "nx run grosshery-mobile:dev",
		"test:grosshery-mobile": "nx run grosshery-mobile:test",
		"test:unit:grosshery-mobile": "nx run grosshery-mobile:test:unit",
		"lint:grosshery-mobile": "nx run grosshery-mobile:lint",
		"format:grosshery-mobile": "nx run grosshery-mobile:format",
		"check:grosshery-mobile": "nx run grosshery-mobile:check"
	},
	"private": true,
	"packageManager": "bun@1.3.13",
	"workspaces": [
		"apps/*"
	],
	"devDependencies": {
		"@nx/vite": "22.7.1",
		"eslint": "^10.2.0",
		"eslint-config-prettier": "^10.1.8",
		"nx": "^22.7.1",
		"prettier": "^3.8.1"
	}
}
