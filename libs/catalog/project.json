{
	"name": "catalog",
	"sourceRoot": "libs/catalog",
	"projectType": "library",
	"targets": {
		"migrate-create": {
			"executor": "nx:run-commands",
			"options": {
				"cwd": "libs/catalog",
				"command": "migrate create -seq -ext sql -dir infrastructure/kerabu/migrations {args.name}"
			}
		},
		"migrate-up": {
			"executor": "nx:run-commands",
			"options": {
				"cwd": "libs/catalog",
				"command": "migrate -database 'postgres://postgres:postgres@localhost:5432/kerabu?sslmode=disable&x-migrations-table=catalog_schema_migrations' -path infrastructure/db/migrations up"
			}
		},
		"migrate-down": {
			"executor": "nx:run-commands",
			"options": {
				"cwd": "libs/catalog",
				"command": "migrate -database 'postgres://postgres:postgres@localhost:5432/kerabu?sslmode=disable&x-migrations-table=catalog_schema_migrations' -path infrastructure/db/migrations down"
			}
		}
	}
}
