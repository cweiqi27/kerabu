{
	"name": "cookbook",
	"sourceRoot": "libs/cookbook",
	"projectType": "library",
	"targets": {
		"migrate-create-write": {
			"executor": "nx:run-commands",
			"options": {
				"cwd": "libs/cookbook",
				"command": "migrate create -seq -ext sql -dir infrastructure/db_write/migrations {args.name}"
			}
		},
		"migrate-create-read": {
			"executor": "nx:run-commands",
			"options": {
				"cwd": "libs/cookbook",
				"command": "migrate create -seq -ext sql -dir infrastructure/db_read/migrations {args.name}"
			}
		},
		"migrate-read-up": {
			"executor": "nx:run-commands",
			"options": {
				"cwd": "libs/cookbook",
				"command": "migrate -database \"$COOKBOOK_READ_POSTGRES_STR?sslmode=disable&x-migrations-table=cookbook_read_schema_migrations\" -path infrastructure/db_read/migrations up"
			}
		},
		"migrate-read-down": {
			"executor": "nx:run-commands",
			"options": {
				"cwd": "libs/cookbook",
				"command": "migrate -database \"$COOKBOOK_READ_POSTGRES_STR?sslmode=disable&x-migrations-table=cookbook_read_schema_migrations\" -path infrastructure/db_read/migrations down"
			}
		},
		"migrate-write-up": {
			"executor": "nx:run-commands",
			"options": {
				"cwd": "libs/cookbook",
				"command": "migrate -database \"$COOKBOOK_WRITE_POSTGRES_STR?sslmode=disable&x-migrations-table=cookbook_write_schema_migrations\" -path infrastructure/db_write/migrations up"
			}
		},
		"migrate-write-down": {
			"executor": "nx:run-commands",
			"options": {
				"cwd": "libs/cookbook",
				"command": "migrate -database \"$COOKBOOK_WRITE_POSTGRES_STR?sslmode=disable&x-migrations-table=cookbook_write_schema_migrations\" -path infrastructure/db_write/migrations down"
			}
		},
		"sqlc-generate": {
			"executor": "nx:run-commands",
			"options": {
				"cwd": "libs/cookbook",
				"command": "sqlc generate"
			}
		}
	}
}
