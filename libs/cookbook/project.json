{
	"name": "cookbook",
	"sourceRoot": "libs/cookbook",
	"projectType": "library",
	"targets": {
		"migrate-create": {
			"executor": "nx:run-commands",
			"options": {
				"cwd": "libs/cookbook",
				"command": "migrate create -seq -ext sql -dir infrastructure/db/migrations {args.name}"
			}
		},
		"migrate-up": {
			"executor": "nx:run-commands",
			"options": {
				"cwd": "libs/cookbook",
				"command": "migrate -database \"$KERABU_POSTGRES_STR?sslmode=disable&x-migrations-table=cookbook_schema_migrations\" -path infrastructure/db/migrations up"
			}
		},
		"migrate-down": {
			"executor": "nx:run-commands",
			"options": {
				"cwd": "libs/cookbook",
				"command": "migrate -database \"$KERABU_POSTGRES_STR?sslmode=disable&x-migrations-table=cookbook_schema_migrations\" -path infrastructure/db/migrations down"
			}
		},
		"sqlc-generate": {
			"executor": "nx:run-commands",
			"options": {
				"cwd": "libs/cookbook",
				"command": "sqlc generate"
			}
		},
		"echo-test": {
			"executor": "nx:run-commands",
			"options": {
				"cwd": "libs/cookbook",
				"command": "echo $KERABU_POSTGRES_STR"
			}
		}
	}
}
