---
import Layout from '../layouts/Layout.astro';
import { getCollection } from 'astro:content';
import ContactSection from '../components/ContactSection.svelte';

const experiences = await getCollection('experience');
const sortedExperiences = [...experiences].sort((a, b) => {
  const dateA = a.data.period_start;
  const dateB = b.data.period_start;
  if (a.data.period_end === null && b.data.period_end !== null) return -1;
  if (a.data.period_end !== null && b.data.period_end === null) return 1;
  return dateB.localeCompare(dateA);
});
---

<Layout>
  <div class="min-h-screen w-full">
    <!-- Nav -->
    <nav class="w-full flex items-center justify-between px-8 md:px-16 lg:px-24 py-8">
      <div class="font-heading text-lg font-light tracking-widest uppercase text-accent">
        K. Tanaka
      </div>
      <div class="flex items-center gap-6">
        <a href="#work" class="text-xs tracking-widest uppercase text-muted hover:text-accent transition-colors duration-300">Work</a>
        <a href="#contact" class="text-xs tracking-widest uppercase text-muted hover:text-accent transition-colors duration-300">Contact</a>
        <button
          id="themeToggle"
          class="cursor-pointer border border-muted rounded-full p-2 bg-transparent text-text hover:border-accent hover:text-accent transition-all duration-300"
          aria-label="Toggle theme"
        >
          <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="sun-icon"><circle cx="12" cy="12" r="5"></circle><line x1="12" y1="1" x2="12" y2="3"></line><line x1="12" y1="21" x2="12" y2="23"></line><line x1="4.22" y1="4.22" x2="5.64" y2="5.64"></line><line x1="18.36" y1="18.36" x2="19.78" y2="19.78"></line><line x1="1" y1="12" x2="3" y2="12"></line><line x1="21" y1="12" x2="23" y2="12"></line><line x1="4.22" y1="19.78" x2="5.64" y2="18.36"></line><line x1="18.36" y1="5.64" x2="19.78" y2="4.22"></line></svg>
          <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="moon-icon hidden"><path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"></path></svg>
        </button>
      </div>
    </nav>

    <!-- Hero -->
    <section class="px-8 md:px-16 lg:px-24 pt-16 pb-32 md:pt-24 md:pb-40 flex items-start justify-between">
      <div class="max-w-2xl opacity-0 translate-y-6 transition-all duration-700 ease-out animate-fade-in">
        <div class="flex items-center gap-4 mb-10">
          <svg width="40" height="2" class="text-accent">
            <line x1="0" y1="1" x2="40" y2="1" stroke="currentColor" stroke-width="1" class="line-draw"/>
          </svg>
          <span class="text-xs tracking-widest uppercase text-muted">Software Developer</span>
        </div>
        <h1 class="font-heading text-5xl md:text-7xl font-light leading-tight mb-8 tracking-tight">
          Kenji Tanaka
        </h1>
        <p class="text-base font-light leading-relaxed text-muted max-w-md" style="line-height: 1.8;">
          Crafting quiet, purposeful software — where simplicity meets intention, and every line of code serves a reason.
        </p>
      </div>
      <div class="hidden lg:flex items-start pt-8">
        <div class="w-[120px] h-[120px] border-2 border-muted rounded-full border-t-transparent -rotate-30 opacity-30"></div>
      </div>
    </section>

    <!-- Divider -->
    <div class="px-8 md:px-16 lg:px-24">
      <div class="border-t border-muted" style="border-top: 1px solid; opacity: 0.4;"></div>
    </div>

    <!-- Work -->
    <section id="work" class="px-8 md:px-16 lg:px-24 py-24 md:py-32">
      <div class="flex items-center gap-4 mb-16 opacity-0 translate-y-6 transition-all duration-700 ease-out animate-fade-in">
        <span class="text-xs tracking-widest uppercase text-muted">Selected Work</span>
        <svg width="40" height="2" class="text-accent">
          <line x1="0" y1="1" x2="40" y2="1" stroke="currentColor" stroke-width="1" />
        </svg>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-8 lg:gap-12">
        <!-- Project 1 -->
        <div class="pb-8 opacity-0 translate-y-6 transition-all duration-700 ease-out animate-fade-in project-card" style="transition-delay: 0.1s;">
          <div class="bg-surface aspect-video rounded-sm mb-6 flex items-center justify-center border border-muted" style="opacity: 0.6;">
            <svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" class="text-muted" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polygon points="12 2 2 7 12 12 22 7 12 2"></polygon><polyline points="2 17 12 22 22 17"></polyline><polyline points="2 12 12 17 22 12"></polyline></svg>
          </div>
          <span class="text-xs tracking-widest uppercase text-muted">01</span>
          <h3 class="font-heading text-2xl font-light mt-2 mb-3">Kumo</h3>
          <p class="text-sm font-light text-muted leading-relaxed">A cloud infrastructure tool built for clarity. Minimal interface, maximum control.</p>
        </div>
        <!-- Project 2 -->
        <div class="pb-8 opacity-0 translate-y-6 transition-all duration-700 ease-out animate-fade-in project-card" style="transition-delay: 0.2s;">
          <div class="bg-surface aspect-video rounded-sm mb-6 flex items-center justify-center border border-muted" style="opacity: 0.6;">
            <svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" class="text-muted" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="4 17 10 11 4 5"></polyline><line x1="12" y1="19" x2="20" y2="19"></line></svg>
          </div>
          <span class="text-xs tracking-widest uppercase text-muted">02</span>
          <h3 class="font-heading text-2xl font-light mt-2 mb-3">Shizuka</h3>
          <p class="text-sm font-light text-muted leading-relaxed">A CLI framework that values silence — only speaks when spoken to.</p>
        </div>
        <!-- Project 3 -->
        <div class="pb-8 opacity-0 translate-y-6 transition-all duration-700 ease-out animate-fade-in project-card" style="transition-delay: 0.3s;">
          <div class="bg-surface aspect-video rounded-sm mb-6 flex items-center justify-center border border-muted" style="opacity: 0.6;">
            <svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" class="text-muted" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M20.24 12.24a6 6 0 0 0-8.49-8.49L5 10.5V19h8.5z"></path><line x1="16" y1="8" x2="2" y2="22"></line><line x1="17.5" y1="15" x2="9" y2="15"></line></svg>
          </div>
          <span class="text-xs tracking-widest uppercase text-muted">03</span>
          <h3 class="font-heading text-2xl font-light mt-2 mb-3">Kaze</h3>
          <p class="text-sm font-light text-muted leading-relaxed">Lightweight state management. Like wind — present everywhere, touching nothing unnecessarily.</p>
        </div>
      </div>
    </section>

    <!-- Divider -->
    <div class="px-8 md:px-16 lg:px-24">
      <div class="border-t border-muted" style="border-top: 1px solid; opacity: 0.4;"></div>
    </div>

    <!-- Experience -->
    <section class="px-8 md:px-16 lg:px-24 py-24 md:py-32">
      <div class="flex items-center gap-4 mb-16 opacity-0 translate-y-6 transition-all duration-700 ease-out animate-fade-in">
        <span class="text-xs tracking-widest uppercase text-muted">Experience</span>
        <svg width="40" height="2" class="text-accent">
          <line x1="0" y1="1" x2="40" y2="1" stroke="currentColor" stroke-width="1" />
        </svg>
      </div>
      <div class="space-y-12 md:space-y-16">
        {sortedExperiences.map((exp, index) => (
          <div class="opacity-0 translate-y-6 transition-all duration-700 ease-out animate-fade-in" style={`transition-delay: ${(index + 1) * 0.1}s;`}>
            <div class="flex flex-col md:flex-row md:items-center md:justify-between md:gap-8 mb-3">
              <div>
                <h3 class="font-heading text-2xl font-light">{exp.data.role}</h3>
                <p class="text-sm text-muted mt-1">{exp.data.company_name}</p>
              </div>
              <span class="text-xs tracking-widest uppercase text-muted mt-2 md:mt-0">
                {exp.data.period_start}{exp.data.period_end ? ` – ${exp.data.period_end}` : ' – Present'}
              </span>
            </div>
            <div class="border-t border-muted" style="border-top: 1px solid; opacity: 0.25; margin-top: 12px;"></div>
          </div>
        ))}
      </div>
    </section>

    <!-- Divider -->
    <div class="px-8 md:px-16 lg:px-24">
      <div class="border-t border-muted" style="border-top: 1px solid; opacity: 0.4;"></div>
    </div>

    <!-- Contact -->
    <section id="contact" class="px-8 md:px-16 lg:px-24 py-24 md:py-32">
      <div class="max-w-lg opacity-0 translate-y-6 transition-all duration-700 ease-out animate-fade-in">
        <span class="text-xs tracking-widest uppercase text-muted">Get in Touch</span>
        <p class="font-heading text-3xl md:text-4xl font-light mt-6 mb-10 leading-snug">
          Let&apos;s build something quiet and meaningful together.
        </p>
        <ContactSection client:visible />
      </div>
    </section>

    <!-- Footer -->
    <footer class="px-8 md:px-16 lg:px-24 py-12">
      <div class="flex items-center justify-between">
        <span class="text-xs text-muted">© 2024</span>
        <div class="flex gap-6">
          <a href="#" class="text-muted hover:text-accent transition-colors duration-300" aria-label="GitHub">
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/></svg>
          </a>
          <a href="#" class="text-muted hover:text-accent transition-colors duration-300" aria-label="LinkedIn">
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M19 0h-14c-2.761 0-5 2.239-5 5v14c0 2.761 2.239 5 5 5h14c2.762 0 5-2.239 5-5v-14c0-2.761-2.238-5-5-5zm-11 19h-3v-11h3v11zm-1.5-12.268c-.966 0-1.75-.79-1.75-1.764s.784-1.764 1.75-1.764 1.75.79 1.75 1.764-.783 1.764-1.75 1.764zm13.5 12.268h-3v-5.604c0-3.368-4-3.113-4 0v5.604h-3v-11h3v1.765c1.396-2.586 7-2.777 7 2.476v6.759z"/></svg>
          </a>
          <a href="#" class="text-muted hover:text-accent transition-colors duration-300" aria-label="Twitter">
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/></svg>
          </a>
        </div>
      </div>
    </footer>
  </div>
</Layout>

<script>
  // Theme toggle
  const themeToggle = document.getElementById('themeToggle');
  const sunIcon = themeToggle?.querySelector('.sun-icon') as HTMLElement;
  const moonIcon = themeToggle?.querySelector('.moon-icon') as HTMLElement;
  let isDark = false;

  themeToggle?.addEventListener('click', () => {
    isDark = !isDark;
    document.documentElement.classList.toggle('dark', isDark);
    if (sunIcon) sunIcon.style.display = isDark ? 'none' : 'block';
    if (moonIcon) moonIcon.style.display = isDark ? 'block' : 'none';
  });

  // Scroll reveal
  const observer = new IntersectionObserver(
    (entries) => {
      entries.forEach((e) => {
        if (e.isIntersecting) {
          e.target.classList.add('visible');
        }
      });
    },
    { threshold: 0.1 }
  );
  document.querySelectorAll('.animate-fade-in').forEach((el) => observer.observe(el));

  // Smooth scroll
  document.querySelectorAll('a[href^="#"]').forEach((a) => {
    a.addEventListener('click', (e) => {
      e.preventDefault();
      const target = document.querySelector((a as HTMLAnchorElement).getAttribute('href')!);
      if (target) target.scrollIntoView({ behavior: 'smooth' });
    });
  });
</script>

<style>
  .animate-fade-in {
    opacity: 0;
    transform: translateY(24px);
  }
  .animate-fade-in.visible {
    opacity: 1;
    transform: translateY(0);
  }

  .project-card {
    position: relative;
    overflow: hidden;
  }
  .project-card::after {
    content: "";
    position: absolute;
    bottom: 0;
    left: 0;
    width: 0;
    height: 2px;
    background: var(--accent);
    transition: width 0.5s ease;
  }
  .project-card:hover::after {
    width: 100%;
  }

  @keyframes dash {
    to {
      stroke-dashoffset: 0;
    }
  }
  .line-draw {
    stroke-dasharray: 200;
    stroke-dashoffset: 200;
    animation: dash 1.5s ease forwards;
  }
</style>